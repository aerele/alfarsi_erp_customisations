{
    "Sales Order": [
		{
			"label": "Credit Amount Within Limit",
			"fieldname": "custom_within_tolerance_amount",
			"fieldtype": "Check",
			"insert_after": "custom_sales_person_name",
			"module": "Alfarsi Selling Customisations"
		},
        {
            "label": "Credit Days Within Limit",
			"fieldname": "custom_within_tolerance_days",
			"fieldtype": "Check",
			"insert_after": "custom_within_tolerance_amount",
			"module": "Alfarsi Selling Customisations"
        },
        {
            "label": "Override Applied",
			"fieldname": "custom_override_applied",
			"fieldtype": "Check",
			"default": 0,
			"hidden": 1,
			"no_copy": 1,
			"read_only": 1,
			"insert_after": "custom_within_tolerance_days",
			"module": "Alfarsi Selling Customisations"
        },
		{
			"label": "Payment Status",
			"fieldname": "custom_payment_status",
			"fieldtype": "Select",
			"options": "Unpaid\nPartially Paid\nPaid",
			"read_only": 1,
			"no_copy": 1,
			"depends_on": "eval:doc.from_ecommerce == 1",
			"insert_after": "custom_override_applied",
			"module": "Alfarsi Selling Customisations"
		}
    ]
}